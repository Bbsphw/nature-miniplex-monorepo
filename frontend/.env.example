# -------------------------------------------------------------------
# Nature MiniPlex Frontend - Environment Variables Template
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้คือเทมเพลต (.env.example) สามารถ commit ลง Git ได้
# ห้ามใส่ค่ารหัสผ่านหรือ API Key จริงๆ ลงในไฟล์นี้เด็ดขาด
# ให้ copy ไฟล์นี้ไปสร้างเป็น .env.local เพื่อใช้งานบนเครื่องตัวเอง
# -------------------------------------------------------------------

# API Base URL สำหรับฝั่ง Frontend เรียกใช้งาน (Default ASP.NET Core Backend Port 5000)
NEXT_PUBLIC_API_URL="http://localhost:5000"

# Public Site Base URL (Default Next.js Dev Server Port 3000)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ตัวอย่าง API Key สำหรับบริการภายนอก
NEXT_PUBLIC_MAP_API_KEY="your_public_api_key_here"

# Secret สำหรับการทำ Authentication (เช่น NextAuth.js / JWT Session Guard)
# NEXTAUTH_SECRET="your_super_secret_string_for_nextauth"
# NEXTAUTH_URL="http://localhost:3000"

# Seat Grid Real-Time Polling Configurations
NEXT_PUBLIC_ENABLE_POLLING="true"
NEXT_PUBLIC_SEAT_REFETCH_INTERVAL="5000"
