# -------------------------------------------------------------------
# Nature MiniPlex Frontend - Environment Variables Template
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้คือเทมเพลต (.env.example) สามารถ commit ลง Git ได้
# ห้ามใส่ค่ารหัสผ่านหรือ API Key จริงๆ ลงในไฟล์นี้เด็ดขาด
# ให้ copy ไฟล์นี้ไปสร้างเป็น .env.local เพื่อใช้งานบนเครื่องตัวเอง
# -------------------------------------------------------------------

# API Base URL สำหรับฝั่ง Frontend เรียกใช้งาน
NEXT_PUBLIC_API_URL="http://localhost:5000"

# ตัวอย่าง API Key สำหรับบริการภายนอก
NEXT_PUBLIC_MAP_API_KEY="your_public_api_key_here"

# Secret สำหรับการทำ Authentication (เช่น NextAuth.js)
# NEXTAUTH_SECRET="your_super_secret_string_for_nextauth"
# NEXTAUTH_URL="http://localhost:3000"
