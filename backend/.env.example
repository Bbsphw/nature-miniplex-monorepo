# -------------------------------------------------------------------
# Nature MiniPlex - Environment Variables Template
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้คือเทมเพลต (.env.example) สามารถ commit ลง Git ได้
# ห้ามใส่รหัสผ่านจริง หรือ Secret จริงๆ ลงในไฟล์นี้เด็ดขาด
# ให้ copy ไฟล์นี้ไปสร้างเป็นไฟล์ .env และ .env.local สำหรับใช้งานจริง
# -------------------------------------------------------------------

# =========================================
# Application Settings
# =========================================
ASPNETCORE_ENVIRONMENT="Development"
PORT="5000"
HTTPS_PORT="5001"

# =========================================
# Database Connection
# =========================================
# เปลี่ยน username, password และชื่อ db ตามสภาพแวดล้อมที่รัน
CONNECTIONSTRINGS__DEFAULTCONNECTION="Server=localhost;Database=NatureMiniPlexDb;User Id=sa;Password=Your_Secure_Password_123!;TrustServerCertificate=True;"

# =========================================
# JWT Authentication
# =========================================
# ความยาวอย่างน้อย 32 ตัวอักษร
JWT__SECRETKEY="Your_Super_Secret_JWT_Key_For_Development_Only!"
JWT__ISSUER="NatureMiniPlexApi"
JWT__AUDIENCE="NatureMiniPlexClient"
JWT__EXPIREMINUTES="120"

# =========================================
# External Services / 3rd Party
# =========================================
# ตัวอย่างการตั้งค่า SMTP สำหรับส่งอีเมล
SMTP__HOST="smtp.mailtrap.io"
SMTP__PORT="2525"
SMTP__USERNAME="your_mailtrap_user"
SMTP__PASSWORD="your_mailtrap_pass"
