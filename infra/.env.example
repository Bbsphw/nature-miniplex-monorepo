# -------------------------------------------------------------------
# 🎬 Nature MiniPlex Infra - Environment Variables Template (.env.example)
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้คือเทมเพลต (.env.example) สำหรับ commit ลง Git VCS
# ค่าในไฟล์นี้จะถูกนำไปใช้โดย infra/docker/docker-compose.yml และ Terraform
# คัดลอกไฟล์นี้ไปเป็น .env ในโฟลเดอร์เดียวกันเพื่อใช้งานในสภาพแวดล้อม Local / Staging
# -------------------------------------------------------------------

# ===================================================================
# 1. ฐานข้อมูล (Database Configuration - MS SQL Server 2022)
# ===================================================================
DB_SERVER="sqlserver"
DB_NAME="NatureMiniPlexDb"
SA_PASSWORD="NaturePlex@2026!"
SQL_PORT="1433"

# ===================================================================
# 2. การกำหนดพอร์ตและการเชื่อมต่อเครือข่าย (Networking & Ports)
# ===================================================================
API_PORT="5000"
FRONTEND_PORT="3000"
MAILPIT_SMTP_PORT="1025"
MAILPIT_WEB_PORT="8025"
CORS__ALLOWEDORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ===================================================================
# 3. ระบบยืนยันตัวตนและความปลอดภัย (JWT Authentication & Security)
# ===================================================================
# Key สำหรับเข้ารหัส JWT ต้องมีความยาวอย่างน้อย 32 อักขระ (256 bits)
JwtSettings__Secret="Development_Secret_Key_For_NatureMiniPlex_Minimum_32_Chars_Long_2026!"
JwtSettings__Issuer="NatureMiniPlex"
JwtSettings__Audience="NatureMiniPlexUsers"
JwtSettings__ExpiryMinutes="120"

# สำหรับ Backward Compatibility ของ Configuration Section "JWT"
JWT__SecretKey="Development_Secret_Key_For_NatureMiniPlex_Minimum_32_Chars_Long_2026!"
JWT__Issuer="NatureMiniPlexApi"
JWT__Audience="NatureMiniPlexClient"
JWT__ExpireMinutes="120"

# ===================================================================
# 4. ระบบส่งอีเมลแจ้งเตือน E-Ticket (SMTP / Mailpit Local Capture)
# ===================================================================
SmtpSettings__Host="mailpit"
SmtpSettings__Port="1025"
SmtpSettings__SenderEmail="noreply@natureminiplex.com"
SmtpSettings__SenderName="Nature MiniPlex Ticketing"
SmtpSettings__EnableSsl="false"
SmtpSettings__Username=""
SmtpSettings__Password=""

# ===================================================================
# 5. การตั้งค่าระบบฝั่ง Frontend Client (Next.js 16 Web App)
# ===================================================================
NEXT_PUBLIC_API_URL="http://localhost:5000"
NEXT_PUBLIC_APP_NAME="Nature MiniPlex"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_AUTH_COOKIE_NAME="admin_token"
NEXT_PUBLIC_MAX_SEATS_PER_BOOKING="4"
