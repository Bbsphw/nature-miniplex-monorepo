# -------------------------------------------------------------------
# 🎬 Nature MiniPlex - Environment Variables Template (.env.example)
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้เป็นเพียงไฟล์แม่แบบ (Template) สำหรับ Commit ลง Git
# ห้ามใส่รหัสผ่านจริง หรือ Secret Key จริงใน Production ลงในไฟล์นี้เด็ดขาด
# ให้นักพัฒนาคัดลอกไฟล์นี้ไปสร้างเป็น .env หรือ .env.local แล้วแก้ไขค่าตามจริง
# -------------------------------------------------------------------

# ===================================================================
# 1. APPLICATION ENVIRONMENT & NETWORKING
# ===================================================================
ASPNETCORE_ENVIRONMENT="Development"
PORT="5000"
HTTPS_PORT="5001"

# Cross-Origin Resource Sharing (CORS)
CORS__ALLOWEDORIGINS="http://localhost:3000,https://yourdomain.com"

# ===================================================================
# 2. DATABASE CONNECTION (SQL SERVER 2022)
# ===================================================================
# ปรับเปลี่ยน Host, Port, Database, User ID และ Password ตามสภาพแวดล้อมจริง
CONNECTIONSTRINGS__DEFAULTCONNECTION="Server=localhost;Database=NatureMiniPlexDb;User Id=sa;Password=Your_Secure_Password_Here!;TrustServerCertificate=True;MultipleActiveResultSets=True;"

# ===================================================================
# 3. JWT AUTHENTICATION & SECURITY
# ===================================================================
# ความยาว Secret Key ต้องไม่น้อยกว่า 32 ตัวอักษร
JWT__SECRETKEY="Put_Your_Super_Secret_JWT_Key_Here_Minimum_32_Chars!"
JWT__ISSUER="NatureMiniPlexApi"
JWT__AUDIENCE="NatureMiniPlexClient"
JWT__EXPIREMINUTES="120"

# ===================================================================
# 4. EXTERNAL SERVICES & SMTP (EMAIL NOTIFICATIONS)
# ===================================================================
# ตั้งค่า SMTP Server (เช่น Mailtrap, SendGrid, หรือ Mailpit)
SMTP__HOST="smtp.mailtrap.io"
SMTP__PORT="2525"
SMTP__USERNAME="your_smtp_username"
SMTP__PASSWORD="your_smtp_password"
SMTP__FROMEMAIL="noreply@natureminiplex.com"
SMTP__FROMNAME="Nature MiniPlex Ticketing"

# ===================================================================
# 5. CACHING & PERFORMANCE (REDIS)
# ===================================================================
REDIS__CONNECTIONSTRING="localhost:6379,abortConnect=false"

# ===================================================================
# 6. LOGGING & MONITORING
# ===================================================================
SERILOG__MINIMUMLEVEL="Information"
