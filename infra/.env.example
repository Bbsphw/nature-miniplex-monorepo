# -------------------------------------------------------------------
# Nature MiniPlex Infra - Environment Variables Template
# -------------------------------------------------------------------
# คำเตือน: ไฟล์นี้คือเทมเพลต (.env.example) สามารถ commit ลง Git ได้
# ค่าในนี้จะถูกใช้โดย docker-compose.yml 
# -------------------------------------------------------------------

# ฐานข้อมูล (Database)
DB_SERVER="db"
DB_NAME="NatureMiniPlexDb"
SA_PASSWORD="Your_Strong_Password_123!"

# พอร์ตสำหรับบริการต่างๆ
SQL_PORT="1433"
API_PORT="5000"
FRONTEND_PORT="3000"

# ระบบความปลอดภัย (Security)
JwtSettings__Secret="Your_Super_Secret_JWT_Key_Change_This_In_Production!"
